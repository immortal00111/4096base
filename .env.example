# Frontend (Vite) env. Copy to .env.local and fill in after deploying contracts.
# These values are PUBLIC (shipped to the browser) — do not put secrets here.
#
# 4096base is a FREE game. The only on-chain pieces are two free, one-per-wallet
# collectible NFTs. There is no payment, fee, fund, or custody contract.

# Deployed NFT addresses on Base Sepolia (printed by the deploy script).
# Premium / early-supporter NFT. Leave blank to hide the mint button.
VITE_PREMIUM_NFT_ADDRESS=
# "Reached 4096" winner badge. Leave blank to hide the badge mint until deployed.
VITE_ACHIEVEMENT_BADGE_ADDRESS=

# Target chain id. Base Sepolia = 84532.
VITE_CHAIN_ID=84532

# WalletConnect / Reown project id (free at https://cloud.reown.com).
# Optional for local testing with injected wallets (MetaMask, Coinbase, Rabby).
VITE_WC_PROJECT_ID=
