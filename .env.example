# Frontend (Vite) env. Copy to .env.local and fill in after deploying contracts.
# These values are PUBLIC (shipped to the browser) — do not put secrets here.

# Deployed contract addresses on Base Sepolia (printed by the deploy script).
VITE_GAME_PAYMENT_ADDRESS=
VITE_DISCOUNT_NFT_ADDRESS=
# "Reached 4096" champion badge. Optional/independent — leave blank to hide the
# badge mint button until the contract is deployed.
VITE_ACHIEVEMENT_BADGE_ADDRESS=

# "4096 Fund": address of the EXISTING audited ERC-4626 vault the app's UI talks
# to directly (NON-CUSTODIAL — the app never holds funds). On Base MAINNET this
# is the Moonwell Flagship USDC MetaMorpho vault:
#   0xc1256Ae5FF1cf2719D4937adb3bbCCab2E00A2Ca
# Leave blank to hide the Fund tab. (No testnet equivalent is wired by default.)
VITE_MORPHO_USDC_VAULT=

# Target chain id. Base Sepolia = 84532.
VITE_CHAIN_ID=84532

# WalletConnect / Reown project id (free at https://cloud.reown.com).
# Optional for local testing with injected wallets (MetaMask, Coinbase, Rabby).
VITE_WC_PROJECT_ID=
