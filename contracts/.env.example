# Copy to contracts/.env and fill in. NEVER commit the real .env.
# Use a throwaway TEST wallet — only put a Base Sepolia testnet key here.

# Private key of the deploying wallet (Base Sepolia testnet only).
# Format: 0x-prefixed 64 hex chars.
PRIVATE_KEY=

# Optional: override the default Base Sepolia RPC.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: for `npx hardhat verify` on BaseScan.
BASESCAN_API_KEY=
